# medgen-stacks database configuration
# Copy to .env and fill in values.
# Sourced automatically by all stack scripts.

PGHOST=localhost
PGPORT=5432
PGUSER=medgen
PGPASSWORD=medgen
PGDATABASE=medgen

# Optional: NLM FTP credentials (required for MEDLINE full baseline)
# Register at https://www.nlm.nih.gov/databases/download/pubmed_medline.html
NLM_FTP_USER=
NLM_FTP_PASS=

# Mirror base directory (where downloaded source files are kept)
MEDGEN_MIRROR_DIR=${HOME}/medgen-mirror

# Python interpreter (must have psycopg2 installed)
PYTHON=${PYTHON:-python3}
